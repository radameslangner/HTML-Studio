  "slug": "portuguesSintaxeSubordinacaoAdverbiais",
  "pages": [
    "<div class=\"metadata-header\" style=\"display:none;\">portugues|Sintaxe|subordinacao|adverbiais</div><div class=\"canvas-box\" data-id=\"box-17810048542650.09045188364524914\" style=\"position: absolute; left: 44px; top: 23px; width: 720px; height: 473px; z-index: 26;  \"><p style=\"line-height: 2;\"><span style=\"font-size: 18px;\">A <strong>oração subordinada adverbial</strong> é uma oração que depende da oração principal e exerce a função de <strong>adjunto adverbial</strong>, indicando circunstâncias como:</span></p><ul><li><p>tempo</p></li><li><p>causa</p></li><li><p>condição</p></li><li><p>finalidade</p></li><li><p>consequência</p></li><li><p>concessão</p></li><li><p>comparação</p></li><li><p>conformidade</p></li><li><p>proporção</p></li></ul><p style=\"line-height: 2.5;\">Ela geralmente é introduzida por conjunções subordinativas.</p><p style=\"line-height: 2.5;\"><span style=\"font-size: 18px;\">Podem aparecer sob forma </span><span style=\"color: rgb(165, 74, 74); font-size: 18px;\"><strong><em><u>reduzida</u></em></strong></span><span style=\"font-size: 18px;\"> (</span><span style=\"color: rgb(82, 128, 112); font-size: 18px;\"><strong><em><u>de infinitivo, de gerúndio ou de particípio</u></em></strong></span><span style=\"font-size: 18px;\">)</span></p><p style=\"line-height: 2.5;\"></p><p style=\"line-height: 2.5;\"><span style=\"color: rgb(200, 122, 81); font-size: 18px;\"><strong><em><u>MACETE: trocar o conectivo, conjunção para facilitar a identificação.</u></em></strong></span></p></div>",
    "<div class=\"metadata-header\" style=\"display:none;\">portugues|Sintaxe|subordinacao|adverbiais</div><div class=\"canvas-box\" data-id=\"box-17810053025900.7926041076556066\" style=\"position: absolute; left: 25px; top: 36px; width: 723px; height: 344px; z-index: 43;  \"><p style=\"line-height: 2;\"><span style=\"color: rgb(165, 74, 74); font-size: 30px;\"><strong><em>Causais</em></strong></span><span style=\"font-size: 30px;\"><strong><em> </em></strong></span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Indicam o motivo, arazão do que ocorre na oração principal.</span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Principais: porque, como (= porque), visto que, já que, uma vez que...</span></p><p style=\"line-height: 3;\">Exemplo:</p><p style=\"line-height: 2;\"><span style=\"color: rgb(165, 74, 74); font-size: 20px;\"><strong><em><u>Como chovia muito</u></em></strong></span><span style=\"font-size: 20px;\">, não foi à escola.</span></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p></div>",
    "<div class=\"metadata-header\" style=\"display:none;\">portugues|Sintaxe|subordinacao|adverbiais</div><div class=\"canvas-box\" data-id=\"box-17810057805240.7323102376543165\" style=\"position: absolute; left: 28px; top: 44px; width: 737px; height: 447px; z-index: 14;  \"><p></p></div><div class=\"canvas-box\" data-id=\"box-17810058583550.5136034561316052\" style=\"position: absolute; left: 45px; top: 56px; width: 723px; height: 344px; z-index: 66;  \"><p style=\"line-height: 2;\"><span style=\"color: rgb(165, 74, 74); font-size: 30px;\"><strong><em>Consecutivas</em></strong></span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Indicam o resultado de uma ação.</span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Principais: </span>que (precedido de tão, tanto, tal, tamanho), de modo que, de sorte que...</p><p style=\"line-height: 2;\"><span style=\"color: rgb(200, 122, 81);\"><strong><em><u>sem que </u></em></strong><em><u>( conjunção concessiva que nega).</u></em></span></p><p style=\"line-height: 3;\">Exemplo:</p><p style=\"line-height: 2;\"><span style=\"color: rgb(54, 48, 48); font-size: 20px;\">gritou </span><span style=\"color: rgb(82, 128, 112); font-size: 20px;\">tanto</span><span style=\"color: rgb(54, 48, 48); font-size: 20px;\"> </span><span style=\"color: rgb(82, 128, 112); font-size: 20px;\"><strong><em><u>que</u></em></strong></span><span style=\"color: rgb(165, 74, 74); font-size: 20px;\"><strong><em><u> perdeu o voz.</u></em></strong></span></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p></div>",
    "<div class=\"metadata-header\" style=\"display:none;\">portugues|Sintaxe|subordinacao|adverbiais</div><div class=\"canvas-box\" data-id=\"box-17810080725830.34874481966728854\" style=\"position: absolute; left: 32px; top: 37px; width: 723px; height: 344px; z-index: 70;  \"><p style=\"line-height: 2;\"><span style=\"color: rgb(165, 74, 74); font-size: 30px;\"><strong><em>Concessivas</em></strong></span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Exprimem sentido de oposição, exceção, aceitar uma ideia oposta.</span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Principais: </span><span style=\"color: rgb(200, 122, 81); font-size: 20px;\"><strong><em>é certo que,</em></strong></span><span style=\"font-size: 20px;\"> embora, conquanto, mesmo que, ainda que, por mais que...</span></p><p style=\"line-height: 3;\">Exemplo:</p><p style=\"line-height: 2;\"><span style=\"color: rgb(54, 48, 48); font-size: 20px;\">Foi a escola, </span><span style=\"color: rgb(165, 74, 74); font-size: 20px;\"><strong><em><u>embora chovesse muito.</u></em></strong></span></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p></div>",
    "<div class=\"metadata-header\" style=\"display:none;\">portugues|Sintaxe|subordinacao|adverbiais</div><div class=\"canvas-box\" data-id=\"box-17810083533690.9881742570624991\" style=\"position: absolute; left: 29px; top: 30px; width: 708px; height: 443px; z-index: 78;  \"><p style=\"line-height: 2;\"><span style=\"color: rgb(165, 74, 74); font-size: 30px;\"><strong><em>Condicionais</em></strong></span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Indicam uma hipótese para a realzação de um fato.</span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Principais: se, caso, dede que, contanto que...</span></p><p style=\"line-height: 3;\">Exemplo:</p><p style=\"line-height: 3;\">A condição (se vieres) é uma possível causa</p><p style=\"line-height: 2;\"><span style=\"color: rgb(165, 74, 74); font-size: 20px;\"><strong><em><u>Se vieres,</u></em></strong></span><span style=\"color: rgb(54, 48, 48); font-size: 20px;\"> darei uma festa.</span></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\">A oração principal (darei )é uma possível consequência da condicional.</p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p></div>",
    "<div class=\"metadata-header\" style=\"display:none;\">portugues|Sintaxe|subordinacao|adverbiais</div><div class=\"canvas-box\" data-id=\"box-17810088190420.5961812627967935\" style=\"position: absolute; left: 35px; top: 27px; width: 730px; height: 437px; z-index: 83;  \"><p style=\"line-height: 2;\"><span style=\"color: rgb(165, 74, 74); font-size: 30px;\"><strong><em>Comparativas</em></strong></span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Exprimem uma ideia de comparação entre dois termos.</span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Principais: como, que (antecedido de mais, menos), quanto, </span><span style=\"color: rgb(200, 122, 81); font-size: 20px;\"><strong><em>assim como</em></strong></span><span style=\"font-size: 20px;\">...</span></p><p style=\"line-height: 3;\"><span style=\"color: rgb(82, 128, 112);\"><strong><em><u>assim como [comparativo - unindo orações] assim como [aditivo - unindo termos]</u></em></strong></span></p><p style=\"line-height: 3;\">Exemplo:</p><p style=\"line-height: 3;\"><span style=\"color: rgb(54, 48, 48); font-size: 20px;\">É inteligente </span><span style=\"color: rgb(165, 74, 74); font-size: 20px;\"><strong><em><u>como o pai.</u></em></strong></span></p><p style=\"line-height: 3;\"><span style=\"color: rgb(234, 109, 42);\"><strong><em><u>Atenção para a elipse do verbo!!!</u></em></strong></span></p><p style=\"line-height: 3;\"><span style=\"color: rgb(54, 48, 48); font-size: 20px;\">É inteligente </span><span style=\"color: rgb(165, 74, 74); font-size: 20px;\"><strong><em><u>como o pai </u></em></strong></span><span style=\"color: rgb(82, 128, 112); font-size: 20px;\"><strong><em><u>é</u></em></strong></span><span style=\"color: rgb(165, 74, 74); font-size: 20px;\"><strong><em><u>.</u></em></strong></span></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p></div>",
    "<div class=\"metadata-header\" style=\"display:none;\">portugues|Sintaxe|subordinacao|adverbiais</div><div class=\"canvas-box\" data-id=\"box-17810092062310.6563375007629035\" style=\"position: absolute; left: 27px; top: 30px; width: 723px; height: 344px; z-index: 71;  \"><p style=\"line-height: 2;\"><span style=\"color: rgb(165, 74, 74); font-size: 30px;\"><strong><em>Conformativas</em></strong></span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Indicam conformidade de um fato com outro.</span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Principais: como, conforme, consoante...</span></p><p style=\"line-height: 3;\">Exemplo:</p><p style=\"line-height: 2;\"><span style=\"color: rgb(54, 48, 48); font-size: 20px;\">Não compareceu, </span><span style=\"color: rgb(165, 74, 74); font-size: 20px;\"><strong><em><u>conforme se previa.</u></em></strong></span></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p></div>",
    "<div class=\"metadata-header\" style=\"display:none;\">portugues|Sintaxe|subordinacao|adverbiais</div><div class=\"canvas-box\" data-id=\"box-17810093080490.6856714604323602\" style=\"position: absolute; left: 49px; top: 31px; width: 723px; height: 344px; z-index: 72;  \"><p style=\"line-height: 2;\"><span style=\"color: rgb(165, 74, 74); font-size: 30px;\"><strong><em>Finais</em></strong></span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Indicam a finalidade, o objetivo</span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Principais: a fim de que, que, para que, porque...</span></p><p style=\"line-height: 3;\">Exemplo:</p><p style=\"line-height: 2;\"><span style=\"color: rgb(54, 48, 48); font-size: 20px;\">Comportaram-se </span><span style=\"color: rgb(165, 74, 74); font-size: 20px;\">para que não fossem castigados.</span></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p></div>",
    "<div class=\"metadata-header\" style=\"display:none;\">portugues|Sintaxe|subordinacao|adverbiais</div><div class=\"canvas-box\" data-id=\"box-17810096714720.6317879566986649\" style=\"position: absolute; left: 46px; top: 33px; width: 723px; height: 344px; z-index: 72;  \"><p style=\"line-height: 2;\"><span style=\"color: rgb(165, 74, 74); font-size: 30px;\"><strong><em>Temporais</em></strong></span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Indicam o momento em que ocorreu um fato.</span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Principais: qualdo, mal, enquanto, desde que, logo que...</span></p><p style=\"line-height: 3;\">Exemplo:</p><p style=\"line-height: 2;\"><span style=\"color: rgb(54, 48, 48); font-size: 20px;\">Quando chegou, </span><span style=\"color: rgb(165, 74, 74); font-size: 20px;\"><strong><em><u>todos aplaudiram.</u></em></strong></span></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p></div>",
    "<div class=\"metadata-header\" style=\"display:none;\">portugues|Sintaxe|subordinacao|adverbiais</div><div class=\"canvas-box\" data-id=\"box-17810095118480.2570989549489877\" style=\"position: absolute; left: 38px; top: 37px; width: 723px; height: 344px; z-index: 71;  \"><p style=\"line-height: 2;\"><span style=\"color: rgb(165, 74, 74); font-size: 30px;\"><strong><em>Proporcionais</em></strong></span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Relação entre duas ações em que uma delas acarreta mudança na outra.</span></p><p style=\"line-height: 2;\"><span style=\"font-size: 20px;\">Principais: à medida que, à proporção que, ao passo que...</span></p><p style=\"line-height: 3;\">Exemplo:</p><p style=\"line-height: 2;\"><span style=\"color: rgb(54, 48, 48); font-size: 20px;\">À medida que o tempo passava, </span><span style=\"color: rgb(165, 74, 74); font-size: 20px;\"><strong><em><u>ia ficando mais preocupado.</u></em></strong></span></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p><p style=\"line-height: 2;\"></p></div>"
  ],
