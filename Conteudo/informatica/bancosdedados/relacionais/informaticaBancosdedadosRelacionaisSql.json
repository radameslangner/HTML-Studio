    "<div class=\"metadata-header\" style=\"display:none;\">informatica|BancosDeDados|Relacionais|SQL</div><div class=\"canvas-box\" data-id=\"box-17802582542460.8924466288868869\" style=\"position: absolute; left: 79px; top: 96px; width: 473px; height: auto; z-index: 2;\"><table style=\"min-width: 368px;\"><colgroup><col style=\"min-width: 25px;\"><col style=\"width: 343px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p>Símbolo</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"343\"><p>Significado</p></th></tr><tr><td colspan=\"1\" rowspan=\"1\"><p><code>{n}</code></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"343\"><p>Exatamente n ocorrências</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p>{n,}</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"343\"><p>Pelo menos n ocorrências</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p>{n,m}</p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"343\"><p>Entre n e m ocorências</p></td></tr></tbody></table><p></p></div>",
    "<div class=\"metadata-header\" style=\"display:none;\">informatica|BancosDeDados|Relacionais|SQL</div><div class=\"canvas-box\" data-id=\"box-17802583188390.25343471847220744\" style=\"position: absolute; left: 65px; top: 93px; width: 532px; height: auto; z-index: 2;\"><table style=\"min-width: 365px;\"><colgroup><col style=\"min-width: 25px;\"><col style=\"width: 340px;\"></colgroup><tbody><tr><th colspan=\"1\" rowspan=\"1\"><p>Símbolo</p></th><th colspan=\"1\" rowspan=\"1\" colwidth=\"340\"><p>Significado</p></th></tr><tr><td colspan=\"1\" rowspan=\"1\"><p><code>[abc]</code></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"340\"><p>a, b ou c</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p><code>[^abc]</code></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"340\"><p>Qualquer caractere exceto a, b ou c</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p><code>[0-9]</code></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"340\"><p>Dígitos de 0 a 9</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p><code>[A-Z]</code></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"340\"><p>Letras maiúsculas</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p><code>\\d</code></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"340\"><p>Dígito (em muitos motores regex)</p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p><code>\\w</code></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"340\"><p>Letra, número ou <code>_</code></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\"><p><code>\\s</code></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"340\"><p>Espaço em branco</p></td></tr></tbody></table><p></p></div>",
