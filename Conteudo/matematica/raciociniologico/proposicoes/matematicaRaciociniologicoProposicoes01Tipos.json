 Q) = Não P ou Não Q</span></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"160\"><p><span style=\"font-size: 14px;\"><strong>P ∨ Q</strong></span></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"119\"><p><span style=\"font-size: 14px;\">¬(P ∨ Q)</span></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"183\"><p><span style=\"font-size: 14px;\"><strong>¬P ∧ ¬Q</strong></span></p></td><td colspan=\"1\" rowspan=\"1\"><p><span style=\"font-size: 14px;\">Não (P ou Q) = Não P e Não Q</span></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"160\"><p><span style=\"font-size: 14px;\"><strong>P → Q</strong></span></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"119\"><p><span style=\"font-size: 14px;\">¬(P → Q)</span></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"183\"><p><span style=\"font-size: 14px;\"><strong>P ∧ ¬Q</strong></span></p></td><td colspan=\"1\" rowspan=\"1\"><p><span style=\"font-size: 14px;\">A negação do \"se P então Q\" ocorre quando P é verdadeiro e Q é falso</span></p></td></tr><tr><td colspan=\"1\" rowspan=\"1\" colwidth=\"160\"><p><span style=\"font-size: 14px;\"><strong>P ↔ Q</strong></span></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"119\"><p><span style=\"font-size: 14px;\">¬(P ↔ Q)</span></p></td><td colspan=\"1\" rowspan=\"1\" colwidth=\"183\"><p><span style=\"font-size: 14px;\"><strong>(P ∧ ¬Q) ∨ (¬P ∧ Q)</strong></span></p></td><td colspan=\"1\" rowspan=\"1\"><p><span style=\"font-size: 14px;\">A negação do bicondicional ocorre quando os valores são diferentes</span></p></td></tr></tbody></table><p></p></div>",
